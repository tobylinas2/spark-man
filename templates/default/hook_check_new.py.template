#!/usr/bin/env python3
"""
Hook: 检查是否有新增弹出消息，输出简报。

安装位置: {{HOOKS_DIR}}/check_new.py
由 .claude/settings.json hooks.PreToolUse 调用。
"""

import json
import os
import sqlite3
import sys
from datetime import datetime

WORK_DIR = "{{WORK_DIR}}"
DB_PATH = os.path.join(WORK_DIR, "messages.db")
ME_DIR = os.path.join(WORK_DIR, ".me")
LAST_BRIEF_FILE = os.path.join(ME_DIR, "last_brief")


def get_new_messages(db_path: str, since: str) -> list:
    """获取 since 之后新增的 pending popup 消息。"""
    if not os.path.exists(db_path):
        return []
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    if since:
        rows = conn.execute(
            "SELECT * FROM messages WHERE level='popup' AND status='pending' AND created_at > ? ORDER BY created_at",
            [since],
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT * FROM messages WHERE level='popup' AND status='pending' ORDER BY created_at LIMIT 10",
        ).fetchall()
    conn.close()
    return rows


def format_brief(rows: list) -> str:
    """生成简报文本。"""
    if not rows:
        return ""

    lines = []
    lines.append("")
    lines.append("━" * 54)
    lines.append(f"  新消息简报 ({len(rows)} 条)")
    lines.append("━" * 54)

    for i, msg in enumerate(rows, 1):
        summary = ""
        props_raw = msg["props"]
        if props_raw and props_raw != "{}":
            try:
                parsed = json.loads(props_raw) if isinstance(props_raw, str) else props_raw
                summary = parsed.get("summary", "")
            except (json.JSONDecodeError, TypeError):
                pass

        preview = summary if summary else str(msg["data"])[:80]
        meta = ""
        if props_raw and props_raw != "{}":
            try:
                parsed = json.loads(props_raw) if isinstance(props_raw, str) else props_raw
                for key in ("number", "sender", "repo", "group_name"):
                    if key in parsed:
                        meta = f" {parsed[key]}"
                        break
            except (json.JSONDecodeError, TypeError):
                pass

        lines.append(f"  [{i}] {msg['type_name']}{meta}: {preview}")

    lines.append("━" * 54)
    lines.append("")
    return "\n".join(lines)


def main():
    since = ""
    if os.path.exists(LAST_BRIEF_FILE):
        with open(LAST_BRIEF_FILE) as f:
            since = f.read().strip()

    rows = get_new_messages(DB_PATH, since)
    if not rows:
        return

    # 更新 last_brief 时间戳，避免重复输出同一批简报
    now = datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")
    os.makedirs(ME_DIR, exist_ok=True)
    with open(LAST_BRIEF_FILE, "w") as f:
        f.write(now)

    brief = format_brief(rows)
    if brief:
        print(brief, file=sys.stderr)


if __name__ == "__main__":
    main()
